{
    "name": "youssefmansour9/audit-trail-package",
    "description": "Production-grade audit trail package for tracking entity changes with Clean Architecture, CQRS, and PDO storage",
    "keywords": ["audit", "audit-trail", "logging", "cqrs", "clean-architecture", "entity-history"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.3",
        "ext-json": "*",
        "ext-pdo": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AuditTrail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AuditTrail\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage/",
        "analyse": "phpstan analyse src --level 6",
        "check": ["@test", "@analyse"]
    },
    "support": {
        "issues": "https://github.com/YoussefMansour9/audit-trail-package/issues",
        "source": "https://github.com/YoussefMansour9/audit-trail-package"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
